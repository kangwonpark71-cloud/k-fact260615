# Client-visible values. These are bundled into the browser when prefixed with VITE_.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=
VITE_ADMIN_EMAIL=

# Server/Cloudflare Workers values. Keep real values out of Git.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ADMIN_EMAIL=

# AI providers. At least one provider key or the Cloudflare AI binding is required.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# External evidence/news providers.
TAVILY_API_KEY=
GOOGLE_FACTCHECK_API_KEY=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
YOUTUBE_API_KEY=
ECOS_API_KEY=
KOSIS_API_KEY=

# Optional security keys. Use 64 hex chars for ENCRYPTION_KEY.
ENCRYPTION_KEY=
RESULT_SIGNING_KEY=
CF_GATEWAY_ID=
